# ---- App ----
APP_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
# Where the Supabase invite / set-password email link redirects. Must also be added to
# the Supabase project's Auth -> URL Configuration -> Redirect URLs.
INVITE_REDIRECT_URL=https://flowdesk.vanelsen.net.au/set-password

# ---- Database (asyncpg driver) ----
# Supabase gives a Postgres connection string; use the +asyncpg driver.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flowdesk

# ---- Supabase ----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=<project-ref>
# Server-only. NEVER exposed to the frontend. Set via `flyctl secrets set` in prod.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# ---- JWT verification (asymmetric, via JWKS) ----
JWT_AUDIENCE=authenticated
JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1

# ---- Tests only (a running Postgres for the pytest suite) ----
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/flowdesk_test
